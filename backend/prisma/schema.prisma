generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis]
}

// ----------------------------------------------------------------------
// ENUMS
// ----------------------------------------------------------------------

enum GlobalRole {
  ADMIN
  USER
}

enum BusinessRole {
  OWNER
  MANAGER
  EMPLOYEE
}

enum PetType {
  DOG
  CAT
  BIRD
  RABBIT
  REPTILE
  OTHER
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum JobStatus {
  PENDING
  ACCEPTED
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum EntryType {
  CREDIT
  DEBIT
}

enum LedgerReferenceType {
  JOB_PAYMENT
  TIP
  PAYOUT
  REFUND
  ADJUSTMENT
}

// How a user account authenticates (welcome/sign-in screen: Apple, Google, email)
enum AuthProvider {
  EMAIL
  GOOGLE
  APPLE
}

// Biological sex of a pet — drives the Neutered/Spayed label on the pet profile
enum PetSex {
  MALE
  FEMALE
}

// Category a service offering belongs to (owner "Create service offering" screen)
enum ServiceCategory {
  WALKING
  BOARDING
  DROP_IN
  DAY_CARE
  TRAINING
  GROOMING
  HOUSE_SITTING
}

// Sitter background-check state (employee onboarding: invite → background check → approved)
enum BackgroundCheckStatus {
  NOT_STARTED
  PENDING
  APPROVED
  REJECTED
}

// Overall pet disposition recorded on a job's report card ("😄 Mood: Very Happy")
enum PetMood {
  VERY_HAPPY
  HAPPY
  CALM
  ANXIOUS
  LOW_ENERGY
}

// ----------------------------------------------------------------------
// CORE IDENTITY & MULTI-TENANCY
// ----------------------------------------------------------------------

model User {
  id            String           @id @default(uuid())
  email         String           @unique
  passwordHash  String?          // null for OAuth-only accounts (Google / Apple sign-in)
  authProvider  AuthProvider     @default(EMAIL)
  firstName     String
  lastName      String
  phone         String?
  avatarUrl     String?
  globalRole    GlobalRole       @default(USER)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  memberships   BusinessMember[]
  customer      CustomerProfile?
  messages      Message[]
  jobUpdates    JobUpdate[]
}

model Business {
  id            String             @id @default(uuid())
  name          String
  description   String?
  isActive      Boolean            @default(true)
  isVerified    Boolean            @default(false)  // "Verified" badge on business detail / listings
  heroPhotoUrl  String?                              // hero image on the business profile

  // Human-readable location shown alongside the PostGIS point (e.g. "Ballard", "Seattle")
  addressLine   String?
  city          String?
  neighborhood  String?

  // Flat per-booking fee surfaced at checkout ("flat $6 service fee")
  serviceFeeAmount Decimal?         @db.Decimal(10, 2)

  // Denormalized review aggregates for fast list rendering ("★ 4.9 · 212 reviews")
  avgRating     Decimal?           @db.Decimal(3, 2)
  reviewCount   Int                @default(0)

  // Geospatial Data via PostGIS
  location      Unsupported("geometry(Point, 4326)")?

  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  members       BusinessMember[]
  offerings     ServiceOffering[]
  jobs          Job[]
  ledgerEntries LedgerEntry[]
  reviews       Review[]
  invitations   Invitation[]
  conversations Conversation[]

  @@index([isActive])
  @@index([location], name: "business_location_idx", type: Gist)
}

model BusinessMember {
  id            String                 @id @default(uuid())
  userId        String
  businessId    String
  role          BusinessRole
  title         String?                        // display role, e.g. "Walker & drop-ins", "Boarding lead"
  isActive      Boolean                @default(true)
  backgroundCheckStatus BackgroundCheckStatus  @default(NOT_STARTED)
  onboardingCompletedAt DateTime?              // set when the invite → onboarding flow finishes
  joinedAt      DateTime               @default(now())

  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  business      Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  availability  EmployeeAvailability[]
  assignedJobs  Job[]                  @relation("JobAssignee")
  conversations Conversation[]

  // Ensure a user has only one role per business
  @@unique([userId, businessId])
  @@index([businessId])
  @@index([businessId, isActive])
}

model Invitation {
  id         String       @id @default(uuid())
  businessId String
  email      String
  role       BusinessRole
  token      String       @unique
  expiresAt  DateTime
  isAccepted Boolean      @default(false)

  business   Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

// ----------------------------------------------------------------------
// CUSTOMER & PET DATA
// ----------------------------------------------------------------------

model CustomerProfile {
  id            String    @id @default(uuid())
  userId        String    @unique
  address       String?
  city          String?

  // Geospatial Data via PostGIS
  location      Unsupported("geometry(Point, 4326)")?

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  pets          Pet[]
  jobs          Job[]
  reviews       Review[]
  conversations Conversation[]

  @@index([location], name: "customer_location_idx", type: Gist)
}

model Pet {
  id               String          @id @default(uuid())
  customerId       String
  name             String
  type             PetType
  breed            String?
  age              Int?
  sex              PetSex?
  weightLb         Decimal?        @db.Decimal(5, 2)  // shown as "64 lb", "9 lb"
  photoUrl         String?
  isNeutered       Boolean         @default(false)    // "Neutered" / "Spayed" badge
  isMicrochipped   Boolean         @default(false)    // "Microchipped" badge
  medicalNotes     String?
  careInstructions String?
  homeAccessNotes  String?                            // e.g. "Front-clip harness, hall closet" (non-secret access notes)

  // Vet contact, shared with the assigned sitter (pet profile screen)
  vetName          String?
  vetClinic        String?
  vetPhone         String?

  customer         CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  jobs             Job[]           @relation("JobPets")
}

// ----------------------------------------------------------------------
// SERVICES, SCHEDULING & OPERATIONS
// ----------------------------------------------------------------------

model ServiceOffering {
  id              String   @id @default(uuid())
  businessId      String
  title           String
  category        ServiceCategory?              // optional for now; backfill existing rows before making required
  description     String
  basePrice       Decimal? @db.Decimal(10, 2)   // headline "BASE PRICE" / "from $X"; packages still price individually
  durationMinutes Int
  features        String[]                       // badge chips e.g. "GPS tracked", "Photo updates", "Insured"
  isActive        Boolean  @default(true)

  // Packages and add-ons allow flexible pricing per offering
  packages        ServicePackage[]
  addOns          ServiceOfferingAddOn[]

  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  jobs            Job[]
}

model ServicePackage {
  id                String          @id @default(uuid())
  serviceOfferingId String
  title             String
  sessionsCount     Int             @default(1)
  pricePerSession   Decimal         @db.Decimal(10, 2)
  isActive          Boolean         @default(true)

  serviceOffering   ServiceOffering @relation(fields: [serviceOfferingId], references: [id], onDelete: Cascade)
}

model ServiceOfferingAddOn {
  id                String          @id @default(uuid())
  serviceOfferingId String
  title             String
  pricePerSession   Decimal         @db.Decimal(10, 2)
  perSession        Boolean         @default(true)
  isActive          Boolean         @default(true)

  serviceOffering   ServiceOffering @relation(fields: [serviceOfferingId], references: [id], onDelete: Cascade)
}

model EmployeeAvailability {
  id          String         @id @default(uuid())
  employeeId  String
  dayOfWeek   DayOfWeek
  startTime   String         // Encoded as HH:MM
  endTime     String         // Encoded as HH:MM
  isAvailable Boolean        @default(true)

  employee    BusinessMember @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, dayOfWeek])
}

model Job {
  id                  String          @id @default(uuid())
  jobNumber           Int             @unique @default(autoincrement())  // human-readable "Job #1382"
  businessId          String
  customerId          String
  serviceOfferingId   String
  assigneeId          String?

  status              JobStatus       @default(PENDING)
  respondBy           DateTime?       // request acceptance deadline ("RESPOND BY 7 PM")

  // Session position within a multi-session package booking ("walk 2 of 4")
  sessionNumber       Int?
  totalSessions       Int?

  scheduledStartTime  DateTime
  scheduledEndTime    DateTime
  actualStartTime     DateTime?       // clock-in
  actualEndTime       DateTime?       // clock-out
  acceptedAt          DateTime?       // business accepted the request
  assignedAt          DateTime?       // a sitter was assigned
  distanceMeters      Int?            // route distance walked during the job ("0.8 mi walked so far")
  specialInstructions String?

  price               Decimal         @db.Decimal(10, 2)
  tipAmount           Decimal?        @db.Decimal(10, 2)

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  business            Business        @relation(fields: [businessId], references: [id])
  customer            CustomerProfile @relation(fields: [customerId], references: [id])
  service             ServiceOffering @relation(fields: [serviceOfferingId], references: [id])
  assignee            BusinessMember? @relation("JobAssignee", fields: [assigneeId], references: [id])
  pets                Pet[]           @relation("JobPets")
  ledgerEntries       LedgerEntry[]
  review              Review?
  conversation        Conversation?
  updates             JobUpdate[]
  reportCard          ReportCard?

  @@index([businessId])
  @@index([customerId])
}

model Review {
  id         String          @id @default(uuid())
  jobId      String          @unique
  businessId String
  customerId String
  rating     Int             // 1 to 5 scale
  comment    String?
  tags       String[]        // quick-select highlights e.g. "On time", "Great photos", "Caring & gentle"
  isPublic   Boolean         @default(true)  // "Your review is public on the business's profile"
  createdAt  DateTime        @default(now())

  job        Job             @relation(fields: [jobId], references: [id])
  business   Business        @relation(fields: [businessId], references: [id])
  customer   CustomerProfile @relation(fields: [customerId], references: [id])

  @@index([businessId, rating])
}

// ----------------------------------------------------------------------
// JOB ACTIVITY — LIVE UPDATES & REPORT CARDS
// ----------------------------------------------------------------------
// A JobUpdate is a single timestamped post the assigned sitter shares while a
// job is in progress (a photo, a note, or both) — the "Updates" feed on the
// live job-tracking screen. A ReportCard is the single end-of-job summary the
// sitter fills out at clock-out ("report card after every session").

model JobUpdate {
  id        String   @id @default(uuid())
  jobId     String
  authorId  String   // User who posted — typically the assigned sitter
  note      String?  @db.Text
  photoUrl  String?
  createdAt DateTime @default(now())

  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id])

  @@index([jobId, createdAt(sort: Desc)])
}

model ReportCard {
  id         String   @id @default(uuid())
  jobId      String   @unique
  mood       PetMood?
  peeCount   Int      @default(0)
  poopCount  Int      @default(0)
  ateFood    Boolean  @default(false)
  drankWater Boolean  @default(false)
  gaveTreat  Boolean  @default(false)
  summary    String?  @db.Text  // free-text recap surfaced to the owner after the job
  createdAt  DateTime @default(now())

  job        Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

// ----------------------------------------------------------------------
// FINANCIAL LEDGER
// ----------------------------------------------------------------------

model LedgerEntry {
  id            String              @id @default(uuid())
  businessId    String
  jobId         String?
  entryType     EntryType
  amount        Decimal             @db.Decimal(10, 2)
  balanceAfter  Decimal             @db.Decimal(10, 2)
  currency      String              @default("USD")
  referenceType LedgerReferenceType
  description   String?
  createdAt     DateTime            @default(now())

  business      Business            @relation(fields: [businessId], references: [id])
  job           Job?                @relation(fields: [jobId], references: [id])

  @@index([businessId, createdAt(sort: Desc)])
}

// ----------------------------------------------------------------------
// MESSAGING & COMMUNICATIONS
// ----------------------------------------------------------------------
// A Conversation is always anchored to a Business and has exactly ONE
// of the following participants on the other side:
//   - customerId set  → Owner ↔ Customer conversation
//   - memberId set    → Owner ↔ Employee (BusinessMember) conversation
// The jobId is optional and links a conversation to a specific job.

model Conversation {
  id         String           @id @default(uuid())
  jobId      String?          @unique  // optionally linked to a job
  businessId String
  customerId String?          // set for Owner ↔ Customer
  memberId   String?          // set for Owner ↔ Employee
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  business   Business         @relation(fields: [businessId], references: [id])
  customer   CustomerProfile? @relation(fields: [customerId], references: [id])
  member     BusinessMember?  @relation(fields: [memberId], references: [id])
  job        Job?             @relation(fields: [jobId], references: [id])
  messages   Message[]

  @@index([businessId])
  @@index([customerId])
  @@index([memberId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  content        String       @db.Text
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id])

  // Composite index for rapid cursor-based pagination
  @@index([conversationId, createdAt(sort: Desc)])
}
