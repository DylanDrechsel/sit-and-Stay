generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis]
}

// ----------------------------------------------------------------------
// ENUMS
// ----------------------------------------------------------------------

enum GlobalRole {
  ADMIN
  USER
}

enum BusinessRole {
  OWNER
  MANAGER
  EMPLOYEE
}

enum PetType {
  DOG
  CAT
  BIRD
  RABBIT
  REPTILE
  OTHER
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum JobStatus {
  PENDING
  ACCEPTED
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum EntryType {
  CREDIT
  DEBIT
}

enum LedgerReferenceType {
  JOB_PAYMENT
  TIP
  PAYOUT
  REFUND
  ADJUSTMENT
}

// ----------------------------------------------------------------------
// CORE IDENTITY & MULTI-TENANCY
// ----------------------------------------------------------------------

model User {
  id            String           @id @default(uuid())
  email         String           @unique
  passwordHash  String
  firstName     String
  lastName      String
  phone         String?
  avatarUrl     String?
  globalRole    GlobalRole       @default(USER)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  memberships   BusinessMember[]
  customer      CustomerProfile?
  messages      Message[]
}

model Business {
  id            String             @id @default(uuid())
  name          String
  description   String?
  isActive      Boolean            @default(true)

  // Geospatial Data via PostGIS
  location      Unsupported("geometry(Point, 4326)")?

  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  members       BusinessMember[]
  offerings     ServiceOffering[]
  jobs          Job[]
  ledgerEntries LedgerEntry[]
  reviews       Review[]
  invitations   Invitation[]
  conversations Conversation[]

  @@index([isActive])
  @@index([location], name: "business_location_idx", type: Gist)
}

model BusinessMember {
  id            String                 @id @default(uuid())
  userId        String
  businessId    String
  role          BusinessRole
  isActive      Boolean                @default(true)
  joinedAt      DateTime               @default(now())

  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  business      Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  availability  EmployeeAvailability[]
  assignedJobs  Job[]                  @relation("JobAssignee")
  conversations Conversation[]

  // Ensure a user has only one role per business
  @@unique([userId, businessId])
  @@index([businessId])
  @@index([businessId, isActive])
}

model Invitation {
  id         String       @id @default(uuid())
  businessId String
  email      String
  role       BusinessRole
  token      String       @unique
  expiresAt  DateTime
  isAccepted Boolean      @default(false)

  business   Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

// ----------------------------------------------------------------------
// CUSTOMER & PET DATA
// ----------------------------------------------------------------------

model CustomerProfile {
  id            String    @id @default(uuid())
  userId        String    @unique
  address       String?

  // Geospatial Data via PostGIS
  location      Unsupported("geometry(Point, 4326)")?

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  pets          Pet[]
  jobs          Job[]
  reviews       Review[]
  conversations Conversation[]

  @@index([location], name: "customer_location_idx", type: Gist)
}

model Pet {
  id               String          @id @default(uuid())
  customerId       String
  name             String
  type             PetType
  breed            String?
  age              Int?
  medicalNotes     String?
  careInstructions String?

  customer         CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  jobs             Job[]           @relation("JobPets")
}

// ----------------------------------------------------------------------
// SERVICES, SCHEDULING & OPERATIONS
// ----------------------------------------------------------------------

model ServiceOffering {
  id              String   @id @default(uuid())
  businessId      String
  title           String
  description     String
  basePrice       Decimal  @db.Decimal(10, 2)
  durationMinutes Int
  isActive        Boolean  @default(true)

  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  jobs            Job[]
}

model EmployeeAvailability {
  id          String         @id @default(uuid())
  employeeId  String
  dayOfWeek   DayOfWeek
  startTime   String         // Encoded as HH:MM
  endTime     String         // Encoded as HH:MM
  isAvailable Boolean        @default(true)

  employee    BusinessMember @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, dayOfWeek])
}

model Job {
  id                  String          @id @default(uuid())
  businessId          String
  customerId          String
  serviceOfferingId   String
  assigneeId          String?

  status              JobStatus       @default(PENDING)
  scheduledStartTime  DateTime
  scheduledEndTime    DateTime
  actualStartTime     DateTime?
  actualEndTime       DateTime?
  specialInstructions String?

  price               Decimal         @db.Decimal(10, 2)
  tipAmount           Decimal?        @db.Decimal(10, 2)

  business            Business        @relation(fields: [businessId], references: [id])
  customer            CustomerProfile @relation(fields: [customerId], references: [id])
  service             ServiceOffering @relation(fields: [serviceOfferingId], references: [id])
  assignee            BusinessMember? @relation("JobAssignee", fields: [assigneeId], references: [id])
  pets                Pet[]           @relation("JobPets")
  ledgerEntries       LedgerEntry[]
  review              Review?
  conversation        Conversation?

  @@index([businessId])
  @@index([customerId])
}

model Review {
  id         String          @id @default(uuid())
  jobId      String          @unique
  businessId String
  customerId String
  rating     Int             // 1 to 5 scale
  comment    String?
  createdAt  DateTime        @default(now())

  job        Job             @relation(fields: [jobId], references: [id])
  business   Business        @relation(fields: [businessId], references: [id])
  customer   CustomerProfile @relation(fields: [customerId], references: [id])

  @@index([businessId, rating])
}

// ----------------------------------------------------------------------
// FINANCIAL LEDGER
// ----------------------------------------------------------------------

model LedgerEntry {
  id            String              @id @default(uuid())
  businessId    String
  jobId         String?
  entryType     EntryType
  amount        Decimal             @db.Decimal(10, 2)
  balanceAfter  Decimal             @db.Decimal(10, 2)
  currency      String              @default("USD")
  referenceType LedgerReferenceType
  description   String?
  createdAt     DateTime            @default(now())

  business      Business            @relation(fields: [businessId], references: [id])
  job           Job?                @relation(fields: [jobId], references: [id])

  @@index([businessId, createdAt(sort: Desc)])
}

// ----------------------------------------------------------------------
// MESSAGING & COMMUNICATIONS
// ----------------------------------------------------------------------
// A Conversation is always anchored to a Business and has exactly ONE
// of the following participants on the other side:
//   - customerId set  → Owner ↔ Customer conversation
//   - memberId set    → Owner ↔ Employee (BusinessMember) conversation
// The jobId is optional and links a conversation to a specific job.

model Conversation {
  id         String           @id @default(uuid())
  jobId      String?          @unique  // optionally linked to a job
  businessId String
  customerId String?          // set for Owner ↔ Customer
  memberId   String?          // set for Owner ↔ Employee
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  business   Business         @relation(fields: [businessId], references: [id])
  customer   CustomerProfile? @relation(fields: [customerId], references: [id])
  member     BusinessMember?  @relation(fields: [memberId], references: [id])
  job        Job?             @relation(fields: [jobId], references: [id])
  messages   Message[]

  @@index([businessId])
  @@index([customerId])
  @@index([memberId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  content        String       @db.Text
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id])

  // Composite index for rapid cursor-based pagination
  @@index([conversationId, createdAt(sort: Desc)])
}
