generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis]
}

// ----------------------------------------------------------------------
// ENUMS
// ----------------------------------------------------------------------

enum GlobalRole {
  ADMIN
  USER
}

enum BusinessRole {
  OWNER
  MANAGER
  EMPLOYEE
}

enum PetType {
  DOG
  CAT
  BIRD
  RABBIT
  REPTILE
  OTHER
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum JobStatus {
  PENDING
  ACCEPTED
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DECLINED // business declined the request (owner Requests inbox "Declined" tab)
}

enum EntryType {
  CREDIT
  DEBIT
}

enum LedgerReferenceType {
  JOB_PAYMENT
  TIP
  PAYOUT
  REFUND
  ADJUSTMENT
}

// How a user account authenticates (welcome/sign-in screen: Apple, Google, email)
enum AuthProvider {
  EMAIL
  GOOGLE
  APPLE
}

// Biological sex of a pet — drives the Neutered/Spayed label on the pet profile
enum PetSex {
  MALE
  FEMALE
}

// Category a service offering belongs to (owner "Create service offering" screen)
enum ServiceCategory {
  WALKING
  BOARDING
  DROP_IN
  DAY_CARE
  TRAINING
  GROOMING
  HOUSE_SITTING
}

// Sitter background-check state (employee onboarding: invite → background check → approved)
enum BackgroundCheckStatus {
  NOT_STARTED
  PENDING
  APPROVED
  REJECTED
}

// Overall pet disposition recorded on a job's report card ("😄 Mood: Very Happy")
enum PetMood {
  VERY_HAPPY
  HAPPY
  CALM
  ANXIOUS
  LOW_ENERGY
}

// Purpose of a stored WebAuthn ceremony challenge (admin passkey MFA)
enum WebAuthnChallengeType {
  REGISTRATION
  AUTHENTICATION
}

// ----------------------------------------------------------------------
// CORE IDENTITY & MULTI-TENANCY
// ----------------------------------------------------------------------

model User {
  id            String           @id @default(uuid())
  email         String           @unique
  passwordHash  String?          // null for OAuth-only accounts (Google / Apple sign-in)
  authProvider  AuthProvider     @default(EMAIL)
  firstName     String
  lastName      String
  phone         String?
  avatarUrl     String?
  globalRole    GlobalRole       @default(USER)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  memberships   BusinessMember[]
  customer      CustomerProfile?
  messages      Message[]
  jobUpdates    JobUpdate[]
  adminAuditLogs AdminAuditLog[]         @relation("AdminAuditActor")
  adminCredentials AdminCredential[]     @relation("AdminCredentials")
  adminChallenges  AdminWebAuthnChallenge[] @relation("AdminChallenges")
}

model Business {
  id            String             @id @default(uuid())
  name          String
  description   String?
  isActive      Boolean            @default(true)
  isVerified    Boolean            @default(false)  // "Verified" badge on business detail / listings
  heroPhotoUrl  String?                              // hero image on the business profile

  // Human-readable location shown alongside the PostGIS point (e.g. "Ballard", "Seattle")
  addressLine   String?
  city          String?
  neighborhood  String?

  // Flat per-booking fee surfaced at checkout ("flat $6 service fee")
  serviceFeeAmount Decimal?         @db.Decimal(10, 2)

  // Denormalized review aggregates for fast list rendering ("★ 4.9 · 212 reviews")
  avgRating     Decimal?           @db.Decimal(3, 2)
  reviewCount   Int                @default(0)

  // Geospatial Data via PostGIS
  location      Unsupported("geometry(Point, 4326)")?

  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  members       BusinessMember[]
  offerings     ServiceOffering[]
  bookings      Booking[]
  jobs          Job[]
  ledgerEntries LedgerEntry[]
  reviews       Review[]
  invitations   Invitation[]
  conversations Conversation[]
  favoritedBy   Favorite[]

  @@index([isActive])
  @@index([location], name: "business_location_idx", type: Gist)
}

model BusinessMember {
  id            String                 @id @default(uuid())
  userId        String
  businessId    String
  role          BusinessRole
  title         String?                        // display role, e.g. "Walker & drop-ins", "Boarding lead"
  isActive      Boolean                @default(true)
  backgroundCheckStatus BackgroundCheckStatus  @default(NOT_STARTED)
  onboardingCompletedAt DateTime?              // set when the invite → onboarding flow finishes
  joinedAt      DateTime               @default(now())

  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  business      Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  availability  EmployeeAvailability[]
  assignedJobs  Job[]                  @relation("JobAssignee")
  conversations Conversation[]

  // Ensure a user has only one role per business
  @@unique([userId, businessId])
  @@index([businessId])
  @@index([businessId, isActive])
}

model Invitation {
  id         String       @id @default(uuid())
  businessId String
  email      String
  role       BusinessRole
  token      String       @unique
  expiresAt  DateTime
  isAccepted Boolean      @default(false)

  business   Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

// ----------------------------------------------------------------------
// CUSTOMER & PET DATA
// ----------------------------------------------------------------------

model CustomerProfile {
  id            String    @id @default(uuid())
  userId        String    @unique
  address       String?
  city          String?

  // Geospatial Data via PostGIS
  location      Unsupported("geometry(Point, 4326)")?

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  pets          Pet[]
  bookings      Booking[]
  jobs          Job[]
  reviews       Review[]
  conversations Conversation[]
  favorites     Favorite[]

  @@index([location], name: "customer_location_idx", type: Gist)
}

model Pet {
  id               String          @id @default(uuid())
  customerId       String
  name             String
  type             PetType
  breed            String?
  age              Int?
  sex              PetSex?
  weightLb         Decimal?        @db.Decimal(5, 2)  // shown as "64 lb", "9 lb"
  photoUrl         String?
  isNeutered       Boolean         @default(false)    // "Neutered" / "Spayed" badge
  isMicrochipped   Boolean         @default(false)    // "Microchipped" badge
  medicalNotes     String?
  careInstructions String?
  homeAccessNotes  String?                            // e.g. "Front-clip harness, hall closet" (non-secret access notes)

  // Vet contact, shared with the assigned sitter (pet profile screen)
  vetName          String?
  vetClinic        String?
  vetPhone         String?

  isActive         Boolean         @default(true)  // soft delete — false once removed by the customer

  customer         CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  jobs             Job[]           @relation("JobPets")

  @@index([customerId, isActive])
}

// ----------------------------------------------------------------------
// SERVICES, SCHEDULING & OPERATIONS
// ----------------------------------------------------------------------

model ServiceOffering {
  id              String   @id @default(uuid())
  businessId      String
  title           String
  category        ServiceCategory?              // optional for now; backfill existing rows before making required
  description     String
  basePrice       Decimal? @db.Decimal(10, 2)   // headline "BASE PRICE" / "from $X"; packages still price individually
  durationMinutes Int
  features        String[]                       // badge chips e.g. "GPS tracked", "Photo updates", "Insured"
  isActive        Boolean  @default(true)

  // Packages and add-ons allow flexible pricing per offering
  packages        ServicePackage[]
  addOns          ServiceOfferingAddOn[]

  business        Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  bookings        Booking[]
  jobs            Job[]
}

model ServicePackage {
  id                String          @id @default(uuid())
  serviceOfferingId String
  title             String
  sessionsCount     Int             @default(1)
  pricePerSession   Decimal         @db.Decimal(10, 2)
  isActive          Boolean         @default(true)

  serviceOffering   ServiceOffering @relation(fields: [serviceOfferingId], references: [id], onDelete: Cascade)
  bookings          Booking[]
}

model ServiceOfferingAddOn {
  id                String          @id @default(uuid())
  serviceOfferingId String
  title             String
  pricePerSession   Decimal         @db.Decimal(10, 2)
  perSession        Boolean         @default(true)
  isActive          Boolean         @default(true)

  serviceOffering   ServiceOffering @relation(fields: [serviceOfferingId], references: [id], onDelete: Cascade)
  bookingAddOns     BookingAddOn[]
}

// ----------------------------------------------------------------------
// BOOKINGS
// ----------------------------------------------------------------------
// A Booking is the customer's checkout order: it groups the Jobs created for a
// multi-session package ("4-walk pack" → 4 Job rows), records which package and
// add-ons were purchased, and holds the pack-level total shown at checkout
// ("$104 pack + $10 add-on + $6 fee = $120"). A single ad-hoc session is still
// a Booking with one Job and no servicePackageId.

model Booking {
  id                String          @id @default(uuid())
  businessId        String
  customerId        String
  serviceOfferingId String
  servicePackageId  String?                             // package purchased; null for a single ad-hoc session
  totalPrice        Decimal         @db.Decimal(10, 2)  // full order total shown at checkout, incl. add-ons & service fee
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  business          Business        @relation(fields: [businessId], references: [id])
  customer          CustomerProfile @relation(fields: [customerId], references: [id])
  serviceOffering   ServiceOffering @relation(fields: [serviceOfferingId], references: [id])
  servicePackage    ServicePackage? @relation(fields: [servicePackageId], references: [id])
  jobs              Job[]
  addOns            BookingAddOn[]

  @@index([businessId])
  @@index([customerId])
}

// Add-on selected at checkout, with the price snapshotted at booking time so
// later price changes on the ServiceOfferingAddOn don't rewrite old receipts.
model BookingAddOn {
  id             String               @id @default(uuid())
  bookingId      String
  addOnId        String
  priceAtBooking Decimal              @db.Decimal(10, 2)

  booking        Booking              @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  addOn          ServiceOfferingAddOn @relation(fields: [addOnId], references: [id])

  @@unique([bookingId, addOnId])
}

model EmployeeAvailability {
  id          String         @id @default(uuid())
  employeeId  String
  dayOfWeek   DayOfWeek
  startTime   String         // Encoded as HH:MM
  endTime     String         // Encoded as HH:MM
  isAvailable Boolean        @default(true)

  employee    BusinessMember @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, dayOfWeek])
}

model Job {
  id                  String          @id @default(uuid())
  jobNumber           Int             @unique @default(autoincrement())  // human-readable "Job #1382"
  bookingId           String?         // parent checkout order; groups the sessions of a package
  businessId          String
  customerId          String
  serviceOfferingId   String
  assigneeId          String?

  status              JobStatus       @default(PENDING)
  respondBy           DateTime?       // request acceptance deadline ("RESPOND BY 7 PM")

  // Session position within a multi-session package booking ("walk 2 of 4")
  sessionNumber       Int?
  totalSessions       Int?

  scheduledStartTime  DateTime
  scheduledEndTime    DateTime
  actualStartTime     DateTime?       // clock-in
  actualEndTime       DateTime?       // clock-out
  acceptedAt          DateTime?       // business accepted the request
  declinedAt          DateTime?       // business declined the request
  assignedAt          DateTime?       // a sitter was assigned
  distanceMeters      Int?            // route distance walked during the job ("0.8 mi walked so far")
  specialInstructions String?

  // SENSITIVE — per-job home access secret (e.g. lockbox code "4821"). Set by the
  // customer per job, never stored on the Pet. Expose only to the assigned sitter
  // and the business's active OWNER/MANAGER; never in public/list queries or logs.
  accessCode          String?

  price               Decimal         @db.Decimal(10, 2)
  tipAmount           Decimal?        @db.Decimal(10, 2)

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  booking             Booking?        @relation(fields: [bookingId], references: [id])
  business            Business        @relation(fields: [businessId], references: [id])
  customer            CustomerProfile @relation(fields: [customerId], references: [id])
  service             ServiceOffering @relation(fields: [serviceOfferingId], references: [id])
  assignee            BusinessMember? @relation("JobAssignee", fields: [assigneeId], references: [id])
  pets                Pet[]           @relation("JobPets")
  ledgerEntries       LedgerEntry[]
  review              Review?
  conversation        Conversation?
  updates             JobUpdate[]
  reportCard          ReportCard?

  @@index([bookingId])
  @@index([businessId])
  @@index([customerId])
}

model Review {
  id         String          @id @default(uuid())
  jobId      String          @unique
  businessId String
  customerId String
  rating     Int             // 1 to 5 scale
  comment    String?
  tags       String[]        // quick-select highlights e.g. "On time", "Great photos", "Caring & gentle"
  isPublic   Boolean         @default(true)  // "Your review is public on the business's profile"
  createdAt  DateTime        @default(now())

  job        Job             @relation(fields: [jobId], references: [id])
  business   Business        @relation(fields: [businessId], references: [id])
  customer   CustomerProfile @relation(fields: [customerId], references: [id])

  @@index([businessId, rating])
}

// ----------------------------------------------------------------------
// JOB ACTIVITY — LIVE UPDATES & REPORT CARDS
// ----------------------------------------------------------------------
// A JobUpdate is a single timestamped post the assigned sitter shares while a
// job is in progress (a photo, a note, or both) — the "Updates" feed on the
// live job-tracking screen. A ReportCard is the single end-of-job summary the
// sitter fills out at clock-out ("report card after every session").

model JobUpdate {
  id        String   @id @default(uuid())
  jobId     String
  authorId  String   // User who posted — typically the assigned sitter
  note      String?  @db.Text
  photoUrl  String?
  createdAt DateTime @default(now())

  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id])

  @@index([jobId, createdAt(sort: Desc)])
}

model ReportCard {
  id         String   @id @default(uuid())
  jobId      String   @unique
  mood       PetMood?
  peeCount   Int      @default(0)
  poopCount  Int      @default(0)
  ateFood    Boolean  @default(false)
  drankWater Boolean  @default(false)
  gaveTreat  Boolean  @default(false)
  summary    String?  @db.Text  // free-text recap surfaced to the owner after the job
  createdAt  DateTime @default(now())

  job        Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

// ----------------------------------------------------------------------
// FINANCIAL LEDGER
// ----------------------------------------------------------------------

model LedgerEntry {
  id            String              @id @default(uuid())
  businessId    String
  jobId         String?
  entryType     EntryType
  amount        Decimal             @db.Decimal(10, 2)
  balanceAfter  Decimal             @db.Decimal(10, 2)
  currency      String              @default("USD")
  referenceType LedgerReferenceType
  description   String?
  createdAt     DateTime            @default(now())

  business      Business            @relation(fields: [businessId], references: [id])
  job           Job?                @relation(fields: [jobId], references: [id])

  @@index([businessId, createdAt(sort: Desc)])
}

// ----------------------------------------------------------------------
// MESSAGING & COMMUNICATIONS
// ----------------------------------------------------------------------
// A Conversation is always anchored to a Business. Exactly three shapes are
// allowed (application logic must enforce that at least one side is set):
//   - customerId set             → Business ↔ Customer conversation
//   - memberId set               → Business ↔ Employee (BusinessMember) conversation
//   - customerId + memberId set  → group chat: Business + Employee + Customer
// The jobId is optional and links a conversation to a specific job.

model Conversation {
  id         String           @id @default(uuid())
  jobId      String?          @unique  // optionally linked to a job
  businessId String
  customerId String?          // set for Business ↔ Customer and for group chats
  memberId   String?          // set for Business ↔ Employee and for group chats
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  business   Business         @relation(fields: [businessId], references: [id])
  customer   CustomerProfile? @relation(fields: [customerId], references: [id])
  member     BusinessMember?  @relation(fields: [memberId], references: [id])
  job        Job?             @relation(fields: [jobId], references: [id])
  messages   Message[]

  @@index([businessId])
  @@index([customerId])
  @@index([memberId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  content        String       @db.Text
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id])

  // Composite index for rapid cursor-based pagination
  @@index([conversationId, createdAt(sort: Desc)])
}

// ----------------------------------------------------------------------
// FAVORITES
// ----------------------------------------------------------------------
// A customer bookmarking a business ("tap to favorite" paw fill). One row per
// customer/business pair.

model Favorite {
  id         String          @id @default(uuid())
  customerId String
  businessId String
  createdAt  DateTime        @default(now())

  customer   CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  business   Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([customerId, businessId])
  @@index([businessId])
}

// ----------------------------------------------------------------------
// PLATFORM ADMINISTRATION ----------------> NOT USED YET
// ----------------------------------------------------------------------
// Append-only audit trail of every privileged action taken through the admin
// API. Same philosophy as the financial ledger: rows are never updated or
// deleted — a mistaken action is corrected by recording a new, compensating one.
// Every admin mutation MUST write exactly one row here before returning.

model AdminAuditLog {
  id         String   @id @default(uuid())
  actorId    String                 // User (globalRole ADMIN) who performed the action
  action     String                 // namespaced action key, e.g. "business.deactivate", "user.setGlobalRole"
  targetType String?                // entity acted upon, e.g. "Business", "User"
  targetId   String?                // id of that entity
  metadata   Json?                  // structured context (before/after values, reason, etc.)
  ipAddress  String?                // request source IP, when available
  createdAt  DateTime @default(now())

  actor      User     @relation("AdminAuditActor", fields: [actorId], references: [id])

  @@index([actorId, createdAt(sort: Desc)])
  @@index([targetType, targetId])
}

// A registered WebAuthn passkey used as the admin second factor. An admin may
// register multiple (e.g. a laptop platform key + a hardware security key).
model AdminCredential {
  id           String    @id @default(uuid())
  userId       String
  credentialId String    @unique          // base64url credential ID from the authenticator
  publicKey    Bytes                       // COSE public key bytes
  counter      Int       @default(0)       // signature counter for clone/replay detection
  transports   String[]                    // e.g. ["internal", "hybrid", "usb"]
  deviceLabel  String?                     // user-friendly name, e.g. "MacBook Touch ID"
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?

  user         User      @relation("AdminCredentials", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Short-lived server-issued WebAuthn challenge, stored so it can be verified on the
// follow-up request. Consumed (deleted) on verification; expired rows are ignored.
model AdminWebAuthnChallenge {
  id        String                @id @default(uuid())
  userId    String
  challenge String                                    // base64url challenge string
  type      WebAuthnChallengeType
  expiresAt DateTime
  createdAt DateTime              @default(now())

  user      User                  @relation("AdminChallenges", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}
